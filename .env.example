# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your-bot-token-here

# Your Discord Server (Guild) ID
DISCORD_GUILD_ID=your-server-id-here

# The user ID whose messages to prune (used by scripts only)
TARGET_USER_ID=the-users-id-here

# Set to 'true' to preview what would be deleted without actually deleting
DRY_RUN=true

# Moderation Bot Settings
MOD_LOG_CHANNEL_ID=your-mod-log-channel-id-here
WARNING_TIMEOUT_MINUTES=5
CROSS_POST_THRESHOLD=3

# Discord webhook URL for posting status page updates (create one in your status channel)
STATUS_WEBHOOK_URL=

# HTTP server port (default: 3000)
PORT=3000
